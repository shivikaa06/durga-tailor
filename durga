/* style.css */

* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

body {
    font-family: Arial, sans-serif;
    line-height: 1.6;
    color: #333;
    background-color: #f9f9f9;
}

header {
    background-color: #333;
    color: #fff;
    padding: 20px;
    text-align: center;
}

header h1 {
    font-size: 24px;
    margin-bottom: 10px;
}

header p {
    font-size: 18px;
    margin-bottom: 20px;
}

.social-links {
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px;
}

.social-links li {
    margin-right: 10px;
}

.social-links a {
    color: #fff;
    text-decoration: none;
}

.nav ul {
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px;
}

.nav li {
    margin-right: 20px;
}

.nav a {
    color: #333;
    text-decoration: none;
}

.hero {
    background-image: linear-gradient(to bottom, #333, #444);
    background-size: cover;
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    color: #fff;
}

.hero h2 {
    font-size: 48px;
    margin-bottom: 20px;
}

.hero p {
    font-size: 24px;
    margin-bottom: 40px;
}

.about-us {
    background-color: #f7f7f7;
    padding: 20px;
}

.services {
    background-color: #f9f9f9;
    padding: 20px;
}

.services ul {
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px;
}

.services li {
    margin-right: 10px;
}

.services a {
    color: #333;
    text-decoration: none;
}

.contact-us {
    background-color: #f7f7f7;
    padding: 20px;
}

.map-container {
    width: 100%;
    height: 300px;
    border-radius: 10px;
    background-color: #fff;
    margin-bottom: 20px;
}

footer {
    background-color: #333;
    color: #fff;
    padding: 20px;
    text-align: center;
    clear: both;
}

footer ul {
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px;
}

footer li {
    margin-right: 10px;
}

footer a {
    color: #fff;
    text-decoration: none;
}
